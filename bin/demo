#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

FileUtils.chdir APP_ROOT do
  puts "\n=== Preparing database ==="
  system! "bin/rails db:prepare"

  puts "\n=== Downloading database ==="
  raise "COMPRESSED_DB_URL is not defined" unless ENV["COMPRESSED_DB_URL"]

  system! "curl --output initial.sqlite3.bz2 -L #{ENV["COMPRESSED_DB_URL"]}"

  puts "\n=== Copy initial.sqlite3 ==="
  system! "bzcat initial.sqlite3.bz2 > storage/demo.sqlite3"
end
