#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

FileUtils.chdir APP_ROOT do
  puts "\n=== Preparing database ==="
  system! "bin/rails db:prepare"

  puts "\n=== Copy initial.sqlite3 ==="
  system! "bzcat db/demo/initial.sqlite3.bz2 > storage/demo.sqlite3"
end
