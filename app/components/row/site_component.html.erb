<%= tag.li id: id,
           class: "list-group-item list-group-item-action d-flex align-items-center py-1 m-1",
           data: { testid: testid } do %>

  <%= tag.div class: "flex-grow-1" do %>
    <%= tag.div class: "d-flex align-items-center" do %>
      <%= link_to name, sites_show_path(site_name: name),
                        class: "me-2 text-truncate d-inline-block link-secondary fs-6",
                        style: "max-width: 60%;",
                        title: name %>
      <%= tag.span class: "badge rounded-pill me-2 bg-secondary shadow-sm" do %>
        <%= render IconComponent.new("file-earmark") %>
        <%= count %> articles
      <% end %>
      <%= tag.div class: "d-flex flex-wrap align-items-center gap-1" do %>
        <%= render Site::TagGroupComponent.new(site_name: name, collection: collection) %>
      <% end %>
    <% end %>

  <% end %>

  <%= tag.div class: "actions ms-3" do %>
  <% end %>
<% end %>
