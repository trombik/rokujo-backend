<%= tag.li id: id,
           class: "list-group-item list-group-item-action d-flex align-items-center py-3",
           data: { testid: testid } do %>

  <%= tag.div class: "flex-grow-1" do %>
    <%= tag.div class: "d-flex align-items-center mb-1" do %>
      <%= link_to name, sites_show_path(site_name: name),
                        class: "text-decoration-none fw-bold fs-5 text-primary me-2 text-truncate d-inline-block",
                        style: "max-width: 60%;",
                        title: name %>
      <%= tag.span class: "badge rounded-pill bg-secondary shadow-sm" do %>
        <%= render IconComponent.new("file-earmark") %>
        <%= count %> articles
      <% end %>
    <% end %>

    <%= tag.div class: "d-flex flex-wrap align-items-center gap-1" do %>
      <%= render Site::TagGroupComponent.new(site_name: name, collection: collection) %>
    <% end %>
  <% end %>

  <%= tag.div class: "actions ms-3" do %>
  <% end %>
<% end %>
