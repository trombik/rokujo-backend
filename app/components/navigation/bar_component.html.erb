<%= tag.nav class: "navbar navbar-expand-md bg-body-tertiary" do %>
  <%= tag.div class: "container-fluid" do %>
    <%= link_to "Rokujo", root_path, class: "navbar-brand" %>
    <%= render TogglerComponent.new(id: navbar_content_id) %>
    <%= render CollapsableContentComponent.new(id: navbar_content_id) do %>
      <%= tag.ul class: "navbar-nav me-auto mb-2 mb-lg-0" do %>
        <%= render LinkComponent.new(label: "Home", path: root_path, active: true) %>
        <%= render DropDownComponent.new(label: "Menu") do |c| %>
          <% links.each do |item | %>
            <% c.with_item(**item) %>
          <% end %>
        <% end %>
      <% end %>
      <%= render SearchForm::CollocationComponent.new unless current_path_is_root? %>
    <% end %>
  <% end %>
<% end %>
