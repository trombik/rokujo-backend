<%= tag.div class: "d-inline-block position-relative" do %>
  <%= render Shared::ActionButtonComponent.new(
        icon: icon,
        text: label,
        data: { bs_toggle: "collapse", bs_target: "##{id}" },
        aria: { expanded: "false", controls: id }
      ) %>

    <%= tag.div class: "collapse position-absolute end-0 z-3 #{placement_classes}", id: id, style: "min-width: 300px;" do %>
    <%= tag.div class: "p-2 bg-white border rounded shadow" do %>
      <%= render Shared::ClipTextComponent.new(text: value) %>
    <% end %>
  <% end %>
<% end %>
