<%= tag.div class: "modal-content", data: { testid: testid } do %>
  <%= tag.div class: "modal-header" do %>
    <%= tag.h5 class: "modal-title" do %>
      <%= title %>
    <% end %>
    <%= tag.button type: "button",
                   class: "btn-close",
                   aria: { label: t("form.button.close") },
                   data: { bs_dismiss: "modal" } %>
  <% end %>

  <%= tag.div class: "modal-body", style: scrollable_workaround_style do %>
    <%= body %>
  <% end %>

  <%= tag.div class: "modal-footer gap-1" do %>
    <%= tag.button type: "button",
                   class: "btn btn-secondary",
                   data: { bs_dismiss: "modal" },
                   aria: { label: t("form.button.close") } do %>
      <%= t("form.button.close") %>
    <% end %>
    <%= submit_button  %>
  <% end %>
<% end %>
