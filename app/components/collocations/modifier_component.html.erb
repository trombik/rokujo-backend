<%= tag.div class: "card h-100 border-light-subtle shadow-sm" do %>
  <%= tag.div class: "card-header py-1 px-2 bg-light d-flex justify-content-between align-items-center" do %>
    <%= tag.strong class: "small text-uppercase text-secondary" do %>
      <%= type_name %>
    <% end %>
    <%= tag.small class: "text-muted", title: type_desc do %>
      <%= render IconComponent.new("info-circle") %>
    <% end %>
  <% end %>

  <%= tag.div class: "card-body p-2" do %>
    <%= tag.div class: "d-flex flex-wrap gap-1" do %>
      <% patterns.each do |pattern| %>
        <%= render Shared::TokenWithNumberComponent.new(number: pattern.count) do %>
          <%= tag.span pattern.phrase, class: "fw-bold" %>
          <%= tag.span noun, class: "text-dark ms-1", style: "font-size: 0.85em;" %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
