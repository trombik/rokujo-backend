<%= tag.div class: "border border-1 rounded mb-2 bg-white shadow-sm-hover",
            id: dom_id(article_collection),
            data: { testid: testid } do %>
  <%= tag.div class: "py-2 px-3" do %>
    <%= tag.div class: "row align-items-center g-3" do %>

      <%= tag.div class: "col-12 col-md-3" do %>
        <%= link_to articles_link, class: "text-decoration-none" do %>
          <%= tag.span class: "fw-bold text-dark d-block text-truncate" do %>
            <%= article_collection.name %>
          <% end %>
        <% end %>
      <% end %>

      <%# metadata %>
      <%= tag.div class: "col-auto d-flex align-items-center gap-2" do %>
        <%= tag.span class: "badge border small #{key_badge_class}" do %>
          <%= article_collection.key %>
        <% end %>
        <%= tag.span class: "text-muted small d-flex align-items-center" do %>
          <%= render IconComponent.new("files", klass: "me-1") %><%= article_collection.articles.count %>
        <% end %>
      <% end %>

      <%# tags %>
      <%= tag.div class: "col-12 col-md d-flex flex-wrap align-items-center gap-1" do %>
        <%= tag.div class: "ms-1" do %>
          <%= render Forms::CollectionTagSelectorComponent.new(article_collection) %>
        <% end %>
        <%= render Badge::CollectionTagGroupComponent.new(article_collection) %>
      <% end %>

      <%# action dropdown %>
      <%= tag.div class: "col-12 col-md-auto d-flex justify-content-end gap-2" do %>
        <%= tag.div class: "dropdown" do %>
          <%= tag.button class: "btn btn-sm btn-outline-secondary dropdown-toggle border-0",
                         type: "button",
                         data: { bs_toggle: "dropdown" },
                         aria: { expanded: "false" } do %>
            <%= render IconComponent.new("three-dots") %>
          <% end %>
          <%= tag.ul class: "dropdown-menu dropdown-menu-end shadow" do %>
            <%= tag.li do %>
              <%= link_to article_collection_path(article_collection), class: "dropdown-item" do %>
                <%= render IconComponent.new("eye", klass: "me-2") %><%= t("form.button.view") %>
              <% end %>
            <% end %>
            <%= tag.li do %>
              <%= link_to edit_article_collection_path(article_collection), class: "dropdown-item" do %>
                <%= render IconComponent.new("pencil", klass: "me-2") %><%= t("form.button.edit") %>
              <% end %>
            <% end %>
            <%= tag.li do %>
              <hr class="dropdown-divider">
            <% end %>
            <%= tag.li do %>
              <%= button_to article_collection_path(article_collection),
                            method: :delete,
                            class: "dropdown-item text-danger",
                            data: { confirm: t("form.msg.confirm") } do %>
                <%= render IconComponent.new("trash", klass: "me-2") %><%= t("form.button.delete") %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
