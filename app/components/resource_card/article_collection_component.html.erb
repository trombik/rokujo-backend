<div class="border border-1 rounded mb-2 bg-white shadow-sm-hover" id="<%= dom_id article_collection %>">
  <div class="py-2 px-3">
    <div class="row align-items-center g-3 g-md-4">

      <div class="col-12 col-md-3">
        <span class="fw-bold text-dark d-block text-truncate"><%= article_collection.name %></span>
      </div>

      <div class="col-6 col-md-auto">
        <span class="badge <%= article_collection.key == 'site_name' ? 'bg-info-subtle text-info-emphasis' : 'bg-warning-subtle text-warning-emphasis' %> border small">
          <%= article_collection.key %>
        </span>
      </div>

      <div class="col-12 col-md">
        <code class="text-truncate d-block bg-light px-2 py-1 rounded text-muted border-0" style="font-size: 0.85rem;">
          <%= article_collection.value %>
        </code>
      </div>

      <div class="col-6 col-md-auto text-md-center">
        <span class="badge rounded-pill bg-light text-dark border fw-normal">
          <%= article_collection.associated_articles.count %> <small>items</small>
        </span>
      </div>

      <div class="col-12 col-md-auto ms-auto d-flex justify-content-end gap-2">
        <%= link_to t("form.button.view"), article_collection_path(article_collection),
                    class: "btn btn-sm btn-outline-primary flex-fill flex-md-grow-0 px-3" %>
        <%= link_to t("form.button.edit"), edit_article_collection_path(article_collection),
                    class: "btn btn-sm btn-outline-secondary flex-fill flex-md-grow-0 px-3" %>
        <%= button_to t("form.button.delete"), article_collection_path(article_collection),
                      method: :delete,
                      class: "btn btn-sm btn-outline-danger w-100",
                      data: { confirm: t("form.msg.confirm") },
                      form_class: "flex-fill flex-md-grow-0" %>
      </div>
    </div>
  </div>
</div>
