<%= form_with url: sentences_index_path, method: :get, local: true, data: { testid: testid } do |f| %>
  <% help = Forms::CollapsibleHelpComponent.new("full_text_component", help_class: "card card-body shadow-sm") %>
  <%= tag.div class: "col-auto" do %>
    <%= tag.div class: "input-group" do %>
      <%= tag.span class: "input-group-text" do %>
        <%= t(".name") %>
        <%= render help.button_component %>
      <% end %>
      <%= f.text_field :word, value: keyword, class: "form-control", placeholder: t(".placeholder") %>
      <%= f.submit t(".submit"), name: nil, class: "btn btn-primary" %>
    <% end %>
  <% end %>
  <%= render help %>
<% end %>
