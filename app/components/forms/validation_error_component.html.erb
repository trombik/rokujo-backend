<% if resource.errors.any? %>
  <%= tag.div class: "alert alert-danger shadow-sm", role: "alert", data: { testid: "validation_error" } do %>
    <%= tag.h5 t(".validation_failed", count: resource.errors.count), class: "alert-heading" %>
    <%= tag.ul class: "mb-0" do %>
      <% resource.errors.each do |error| %>
        <%= tag.li error.full_message %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
