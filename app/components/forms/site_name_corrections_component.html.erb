<%= tag.h2 do %>
  <%= title_string %>
<% end %>

<% help_for_domain = Forms::CollapsibleHelpComponent.new("site_name_correction_domain",
                                                         help_class: "card card-body shadow-sm") %>
<% help_for_name =   Forms::CollapsibleHelpComponent.new("site_name_correction_name",
                                                         help_class: "card card-body shadow-sm") %>
<%= form_with(model: site_name_correction) do |form| %>

  <%= render Forms::ValidationErrorComponent.new(site_name_correction) %>

  <%= tag.div class: "input-group mb-1 align-items-center" do %>
    <%= tag.span class: "input-group-text" do %>
      <%= form.label :domain, class: "form-label mb-0" %>
      <%= render help_for_domain.button_component %>
    <% end %>
    <%= form.text_field :domain,
                        class: "form-control",
                        placeholder: t(".placeholder.domain"),
                        aria: { describedby: "description-for-domain" } %>
  <% end %>
  <%= tag.div id: "description-for-domain", class: "form-text mb-3" do %>
    <%= t(".form_text_for_domain") %>
  <% end %>
  <%= render help_for_domain %>

  <%= tag.div class: "input-group mb-1 align-items-center" do %>
    <%= tag.span class: "input-group-text" do %>
      <%= form.label :name, class: "form-label mb-0" %>
      <%= render help_for_name.button_component %>
    <% end %>
    <%= form.text_field :name,
                        class: "form-control",
                        placeholder: t(".placeholder.name"),
                        aria: { describedby: "description-for-name" } %>
  <% end %>
  <%= tag.div id: "description-for-name", class: "form-text mb-3" do %>
    <%= t(".form_text_for_name") %>
  <% end %>
  <%= render help_for_name %>

  <%= tag.div class: "mt-4" do %>
    <%= form.submit class: "btn btn-primary px-4" %>
    <%= link_to "Cancel", site_name_corrections_path, class: "btn btn-link text-decoration-none" %>
  <% end %>
<% end %>
