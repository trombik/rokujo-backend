<%= tag.h1 do %>
  <%= title_string %>
<% end %>

<%= form_with(model: site_name_correction) do |form| %>
  <%= render Forms::ValidationErrorComponent.new(site_name_correction) %>

  <%= tag.div class: "mb-3" do %>
    <%= form.label :domain, class: "form-label fw-semibold" %>
    <%= form.text_field :domain, class: "form-control", placeholder: t(".placeholder.domain") %>
  <% end %>

  <%= tag.div class: "mb-3" do %>
    <%= form.label :name, class: "form-label fw-semibold" %>
    <%= form.text_field :name, class: "form-control", placeholder: t(".placeholder.name") %>
  <% end %>

  <%= tag.div class: "mt-4" do %>
    <%= form.submit class: "btn btn-primary px-4" %>
    <%= link_to "Cancel", site_name_corrections_path, class: "btn btn-link text-decoration-none" %>
  <% end %>
<% end %>
