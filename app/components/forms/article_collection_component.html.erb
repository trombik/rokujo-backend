<%= form_with(model: article_collection) do |form| %>
  <% if article_collection.errors.any? %>
    <%= tag.div class: "alert alert-danger shadow-sm", role: "alert" do %>
      <%= tag.h5 "The input has an error. The change has not been saved.", class: "alert-heading" %>
      <%= tag.ul class: "mb-0" do %>
        <% article_collection.errors.each do |error| %>
          <%= tag.li error.full_message %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= tag.div class: "mb-3" do %>
    <%= form.label :name, class: "form-label fw-semibold" %>
    <%= form.text_field :name, class: "form-control" %>
  <% end %>

  <%= tag.div class: "mb-3" do %>
    <%= form.label :key, "Filter key", class: "form-label fw-semibold" %>

    <% ArticleCollection.valid_keys.each do |key| %>
      <%= tag.div do %>
        <%= form.radio_button :key, key, checked: key == "site_name" && article_collection.key.nil? %>
        <%= form.label "key_#{key}", key.humanize, class: "form-check-label" %>
      <% end %>
    <% end %>
  <% end %>

  <%= tag.div class: "mb-3" do %>
    <%= form.label :value, "Value", class: "form-label fw-semibold" %>
    <%= form.text_field :value, class: "form-control" %>
  <% end %>

  <%= tag.div class: "mb-3" do %>
    <%= form.submit %>
  <% end %>
<% end %>
