<%= tag.div class: "container py-4" do %>
  <%= tag.header class: "mb-5 text-center text-md-start" do %>
    <%= tag.h1 class: "h2 fw-bold text-dark" do %><%= t(".title", default: "Corpus Dashboard") %><% end %>
    <%= tag.p class: "text-secondary small" do %><%= Time.zone.now.strftime("%Y-%m-%d %H:%M") %><% end %>
  <% end %>

  <%= render Layout::SectionGridComponent.new(cols_per_row: 3) do |c| %>
    <% c.with_header { "Overall Volume" } %>
    <%
      items = [
        Stats::TotalArticlesComponent.new,
        Stats::TotalSentencesComponent.new,
        Stats::TotalTokenAnalysesComponent.new
      ]
    %>
    <% items.each do |item| %>
      <% c.with_col { render item } %>
    <% end %>
  <% end %>

  <%= render Layout::SectionGridComponent.new(cols_per_row: 3) do |c| %>
    <% c.with_header { "Analysis and Quality" } %>
    <%
      items = [
        Stats::SentenceAnalysisRatioComponent.new,
        Stats::SentencesPerArticleComponent.new,
        Stats::TotalTokenAnalysesComponent.new
      ]
    %>
    <% items.each do |item| %>
      <% c.with_col { render item } %>
    <% end %>
  <% end %>

  <%= render Layout::SectionGridComponent.new(cols_per_row: 2) do |c| %>
    <% c.with_header { "Analysis and Quality" } %>
    <%
      items = [
        Stats::ArticlesBySitenameComponent.new,
        Stats::SentencesBySitenameComponent.new
      ]
    %>
    <% items.each do |item| %>
      <% c.with_col { render item } %>
    <% end %>
  <% end %>
<% end %>
