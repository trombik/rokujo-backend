<% if @site_name_correction.persisted? %>
  <% modal_component = Shared::ModalComponent.new %>
  <%= turbo_stream.append modal_component.target_id do %>
    <%= modal_component.close %>
  <% end %>
<% else %>
  <%= turbo_stream.update Shared::ModalComponent.new.target_id  do %>
      <%= render Forms::SiteNameCorrectionsComponent.new(@site_name_correction, on_success: @on_success) %>
  <% end %>
<% end %>
