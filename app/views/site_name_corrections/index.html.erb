<%= tag.p style: "color: green" do %>
  <%= notice %>
<% end %>

<% content_for :title, "Site name corrections" %>

<%= render Shared::PageTitleComponent.new(title: "Site name corrections") %>

<%= tag.div id: "site_name_corrections" do %>
  <% @site_name_corrections.each do |site_name_correction| %>
    <%= render ResourceCard::SiteNameCorrectionComponent.new(site_name_correction) %>
    <%= tag.p do %>
      <%= link_to "Show this site name correction", site_name_correction %>
    <% end %>
  <% end %>
<% end %>

<%= link_to "New site name correction", new_site_name_correction_path %>
