<%= tag.p style: "color: green" do %>
  <%= notice %>
<% end %>

<% content_for :title, "Article collections" %>

<%= render Shared::PageTitleComponent.new(title: "Article collections") %>

<%= tag.div id: "article_collections" do %>
  <% @article_collections.each do |article_collection| %>
    <%= render ResourceCard::ArticleCollectionComponent.new(article_collection) %>
  <% end %>
<% end %>

<%= link_to "New article collection", new_article_collection_path %>
