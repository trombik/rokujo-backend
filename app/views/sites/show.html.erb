<%= tag.div class: "container align-items-center gap-2 mt-3 mb-3" do %>
  <%= tag.div class: "row align-items-center" do %>
    <%= tag.div class: "col col-sm-10" do %>
      <%= tag.h1 @site_name, class: "mb-0" %>
    <% end %>
    <%= tag.div class: "col-sm" do %>
    <% end %>
  <% end %>
  <%= tag.div class: "row align-items-center" do %>
    <%= tag.div class: "col col-sm-10 my-3" do %>
      <%= render Site::TagGroupComponent.new(site_name: @site_name, collection: @collection) %>
    <% end %>
    <%= tag.div class: "col-sm" do %>
    <% end %>
  <% end %>
  <%= tag.div class: "row" do %>
  <% end %>
<% end %>

<%= tag.div class: "container py-2" do %>
  <% keyword = "site_name:\"#{@site_name}\"" %>
  <%= render SearchForm::FullTextComponent.new(keyword: keyword) %>
<% end %>

<%= tag.div class: "container py-4" do %>
  <%= tag.section class: "mb-5" do %>
    <%= tag.div class: "d-flex align-items-center mb-3" do %>
      <%= tag.h2 class: "h5 mb-0 text-primary fw-bold" do %>Overall Volume<% end %>
      <%= tag.hr class: "flex-grow-1 ms-3 opacity-25" %>
    <% end %>
    <%= tag.div class: "row g-4" do %>
      <%= tag.div class: "col-md-4" do %>
        <%= render Stats::TotalArticlesComponent.new(nil, frame_url: stats_total_articles_path(@site_name))  %>
      <% end %>
      <%= tag.div class: "col-md-4" do %>
        <%= render Stats::TotalSentencesComponent.new(nil, frame_url: stats_total_sentences_path(@site_name)) %>
      <% end %>
      <%= tag.div class: "col-md-4" do %>
        <%= render Stats::TotalTokenAnalysesComponent.new(nil, frame_url: stats_total_token_analyses_path(@site_name)) %>
      <% end %>
    <% end %>
  <% end %>

  <%= tag.section class: "mb-5" do %>
    <%= tag.div class: "d-flex align-items-center mb-3" do %>
      <%= tag.h2 class: "h5 mb-0 text-success fw-bold" do %>Analysis and Quality<% end %>
      <%= tag.hr class: "flex-grow-1 ms-3 opacity-25" %>
    <% end %>
    <%= tag.div class: "row g-4" do %>
      <%= tag.div class: "col-md-4" do %>
        <%= render Stats::SentenceAnalysisRatioComponent.new(nil, frame_url: stats_sentence_analysis_ratio_path(@site_name)) %>
      <% end %>
      <%= tag.div class: "col-md-4" do %>
        <%= render Stats::SentencesPerArticleComponent.new(nil, frame_url: stats_sentences_per_article_path(@site_name)) %>
      <% end %>
      <%= tag.div class: "col-md-4" do %>
        <%= render Stats::TokensPerSentenceComponent.new(nil, frame_url: stats_tokens_per_sentence_path(@site_name)) %>
      <% end %>
    <% end %>

  <% end %>
<% end %>

<%= tag.div class: "container py-4" do %>
  <%= tag.div class: "d-flex align-items-cneter gap-2" do %>
    <%= render Forms::SiteDeleteButtonComponent.new(@site_name) %>
    <%= render Site::RenameButtonComponent.new(@site_name, on_success: "redirect") %>
  <% end %>
<% end %>
