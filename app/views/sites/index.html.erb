<%= tag.div class: "container mt-4" do %>
  <%= tag.div class: "d-flex justify-content-between align-items-center mb-4" do %>
    <%= tag.h1 class: "h3 mb-0 text-gray-800" do %>
      Sites
    <% end %>
    <%= tag.div do %>
      <%= @n_articles_without_site_name %> articles has <%= link_to "no site name", articles_without_site_name_path, class: "link-danger" %>.
    <% end %>
  <% end %>

  <%= tag.div class: "card shadow-sm border-0" do %>
    <%= tag.ul class: "list-group list-group-flush border-top" do %>
      <%= render Row::SiteComponent.with_collection(@sites) %>
    <% end %>
  <% end %>
<% end %>
