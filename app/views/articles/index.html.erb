<%= tag.div class: "container mt-4" do %>
  <%= tag.div class: "d-flex justify-content-between align-items-center mb-4" do %>
    <%= tag.h1 class: "h3 mb-0 text-gray-800" do %>
      Articles
    <% end %>
    <%= tag.div do %>
      <%= @n_articles_without_site_name %> articles has <%= link_to "no site name", articles_without_site_name_path %>.
    <% end %>
  <% end %>
  <%= render SearchForm::FullTextComponent.new %>
  <%= tag.ul do %>
    <%= render Row::ArticleComponent.with_collection(@articles) %>
  <% end %>

  <%= tag.div class: "mt-4 d-flex justify-content-center" do %>
    <%= render Pagination::NaviComponent.new(@pagy) %>
  <% end %>
<% end %>
