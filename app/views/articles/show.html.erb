<%= tag.div class: "container my-4" do %>
  <%= tag.div class: "card" do %>
    <%= tag.div class: "card-body" do %>
      <%= tag.h1 @article.title, class: "card-title fs-4 my-2" %>

      <%= tag.div class: "card-text d-flex justify-content-end gap-2 p-2" do %>
        <% collection = ArticleCollection.find_by(key: "site_name", value: @article.site_name) %>
        <%= render Site::TagGroupComponent.new(site_name: @article.site_name, collection: collection) %>
        <%= render Shared::CollapsedClipboardComponent.new(value: @article.uuid, label: "UUID") %>
      <% end %>
    <% end %>
  <% end %>

  <%= tag.div class: "my-3" do %>
    <% keyword = "site_name:\"#{@article.site_name}\"" %>
    <%= render SearchForm::FullTextComponent.new(keyword: keyword) %>
  <% end %>

  <%= tag.div class: "card" do %>
    <%= tag.div class: "card-body" do %>
      <%= tag.div class: "card-text mt-4" do %>
        <%= sanitize(Tei2htmlService.call(@article.body)) %>
      <% end %>

      <%= tag.div class: "card-footer mt-3" do %>
        <%= link_to "戻る", "/", class: "btn btn-secondary" %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
