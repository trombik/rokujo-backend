<% content_for :title, "Collection tags" %>

<%= tag.h1 "Collection tags" %>

<%= tag.div id: "collection_tags" do %>
  <%= tag.ul class: "list-group" do %>
    <% @collection_tags.each do |collection_tag| %>
      <%= tag.li class: "list-group-item" do %>
        <%= render Row::TagComponent.new(collection_tag) %>
      <% end %>
    <% end %>
  <% end %>
<% end %>

<%= link_to "New collection tag", new_collection_tag_path %>
